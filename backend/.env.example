NODE_ENV=development
PORT=8000
APP_NAME=personal-blog-api
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/personal_blog
CORS_ORIGIN=http://localhost:3000,http://localhost:5173
JWT_ACCESS_SECRET=blog-access-secret
JWT_ACCESS_EXPIRES_IN=2h
JWT_REFRESH_SECRET=blog-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d
COS_SECRET_ID=your-secret-id
COS_SECRET_KEY=your-secret-key
COS_BUCKET=your-bucket-appid
COS_REGION=ap-guangzhou
COS_PUBLIC_BASE_URL=https://your-bucket-appid.cos.ap-guangzhou.myqcloud.com
COS_PATH_PREFIX=uploads
